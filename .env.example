# Supabase — create project at https://supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps API — https://console.cloud.google.com
# Enable: Maps JavaScript API, Street View Static API, Geocoding API, Roads API
VITE_GOOGLE_MAPS_KEY=your-google-maps-key-for-frontend
GOOGLE_MAPS_KEY=your-google-maps-key-for-backend

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key

# Admin email(s) — comma separated
VITE_ADMIN_EMAILS=thanhphong018@gmail.com

# Production URL — set in Netlify env vars
VITE_SITE_URL=https://your-atlas-app.netlify.app
