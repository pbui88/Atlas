# Supabase — create project at https://supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Maps API — https://console.cloud.google.com
# Enable: Maps JavaScript API, Street View Static API, Geocoding API
VITE_GOOGLE_MAPS_KEY=your-google-maps-key-for-frontend
GOOGLE_MAPS_KEY=your-google-maps-key-for-backend

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Positionstack — https://positionstack.com (reverse geocoding, free 25k/month)
POSITIONSTACK_API_KEY=your-positionstack-api-key

# OpenAI — https://platform.openai.com (no longer used for analysis)
OPENAI_API_KEY=your-openai-api-key

# Admin email(s) — comma separated
VITE_ADMIN_EMAILS=admin@example.com

# Production URL — set in Netlify env vars
VITE_SITE_URL=https://your-atlas-app.netlify.app

# Authorize.net — https://www.authorize.net (Accept Hosted payment form)
# Sandbox credentials: https://sandbox.authorize.net
# Signature Key is required to verify webhook notifications (Account >
# Settings > Security Settings > General Security Settings > Manage
# Signature Key). Webhook events to subscribe to: net.authorize.payment.authcapture.created
AUTHORIZENET_API_LOGIN_ID=573bZpxBk3Z
AUTHORIZENET_TRANSACTION_KEY=2kwt98Q7ZY22bRFT
AUTHORIZENET_SIGNATURE_KEY=B0993F632259DA85B6705FEA82235870292194BD7EA85C670FB63CE935D2FEAF841243F9733C14B4D826D01090C92C202D5B067F190B2BB453F4682F58F34119
AUTHORIZENET_ENVIRONMENT=sandbox

# Admin Monitor — alert thresholds (all optional, defaults shown)
# Database/storage alerts trigger at 75% (warning) and 90% (critical) of these limits.
SUPABASE_DB_LIMIT_BYTES=8589934592        # 8 GB  (Supabase Pro plan default)
SUPABASE_STORAGE_LIMIT_BYTES=107374182400 # 100 GB (Supabase Pro plan default)

# Optional 30-day API spend budget — alert at 90% and 100% of this amount
MONTHLY_API_BUDGET_USD=
